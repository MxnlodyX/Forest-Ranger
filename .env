# ===== Database =====
DB_HOST=db
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=app_db

# ===== MySQL container =====
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=app_db

# ===== Flask =====
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=forest-shield-classroom-secret-2026

# ===== Security (course project defaults) =====
# Local dev origin for Vite
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost,http://192.168.1.35:5173,https://192.168.1.35,http://172.20.10.3:5173,https://172.20.10.3
# Keep false for local HTTP. Set true when deploying behind HTTPS.
SESSION_COOKIE_SECURE=false
